#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════╗
# ║              THEME-DOCTOR (D-25)                     ║
# ║  Rerunnable health check for the theme-engine's core  ║
# ║  invariants. Report-only — never mutates state.       ║
# ╚══════════════════════════════════════════════════════╝

set -uo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
STATE_DIR="$HOME/.local/state/theme"
DOTFILES_DIR="$HOME/dotfiles"

# shellcheck source=lib/contract.sh
source "$SCRIPT_DIR/lib/contract.sh"

PASS=0
FAIL=0

check() {
    local desc="$1"
    local ok="$2"
    if [[ "$ok" == "0" ]]; then
        echo "  [PASS] $desc"
        PASS=$((PASS + 1))
    else
        echo "  [FAIL] $desc"
        FAIL=$((FAIL + 1))
    fi
}

echo "theme-doctor — theme-engine health check"
echo ""

# ── adw-gtk-theme installed (THEME-02 root cause) ──────────
pacman -Q adw-gtk-theme >/dev/null 2>&1
check "adw-gtk-theme package installed" "$?"

# ── gsettings resolves to the expected adw theme ───────────
GTK_THEME_VALUE=$(gsettings get org.gnome.desktop.interface gtk-theme 2>/dev/null | tr -d "'")
[[ "$GTK_THEME_VALUE" == "adw-gtk3-dark" ]]
check "gsettings gtk-theme = adw-gtk3-dark (got: ${GTK_THEME_VALUE:-<unset>})" "$?"

# ── state-dir contract present ──────────────────────────────
[[ -f "$STATE_DIR/current-theme" ]]
check "$STATE_DIR/current-theme exists" "$?"

# D-30: file list sourced from contract.json (single source of truth,
# shared with theme-parity) instead of a hardcoded loop. An empty list
# (jq missing, contract.json unreadable) must surface as a loud FAIL —
# not ten per-file checks silently vanishing from the output.
CONTRACT_FILE_LIST="$(contract_files)"
if [[ -z "$CONTRACT_FILE_LIST" ]]; then
    check "contract.json file list readable and non-empty (jq present)" "1"
else
    while IFS= read -r f; do
        [[ -z "$f" ]] && continue
        [[ -f "$STATE_DIR/$f" ]]
        check "$STATE_DIR/$f exists" "$?"
    done <<< "$CONTRACT_FILE_LIST"
fi

# ── walker/yazi wiring symlinks point at the state dir ─────
[[ -L "$HOME/.config/walker/themes/rice/style.css" ]] \
    && [[ "$(readlink -f "$HOME/.config/walker/themes/rice/style.css")" == "$STATE_DIR/walker-style.css" ]]
check "walker style.css symlinked to state dir" "$?"

[[ -L "$HOME/.config/yazi/theme.toml" ]] \
    && [[ "$(readlink -f "$HOME/.config/yazi/theme.toml")" == "$STATE_DIR/yazi.toml" ]]
check "yazi theme.toml symlinked to state dir" "$?"

# ── no stow conflicts for theme-engine (or the repo isn't
#    positioned as $HOME/dotfiles — skip gracefully) ────────
if command -v stow >/dev/null 2>&1 && [[ -d "$DOTFILES_DIR/theme-engine" ]]; then
    (cd "$DOTFILES_DIR" && stow -n theme-engine >/dev/null 2>/tmp/theme-doctor-stow.log)
    check "stow -n theme-engine reports no conflicts" "$?"
else
    echo "  [SKIP] stow -n theme-engine (stow or $DOTFILES_DIR/theme-engine not found)"
fi

# ── walker/elephant health + version-match + provider parity ───────
#    (THEME-01, SCAN-02, D-25). No documented version-pin/compat matrix
#    exists between walker and elephant (RESEARCH "Version compatibility"
#    table — both are independently versioned by the same upstream
#    author, no pin mechanism in install.sh); a responsive `elephant
#    version` alongside a running walker binary is the practical
#    compatibility signal available.
WALKER_CONFIG="$HOME/.config/walker/config.toml"

if command -v elephant >/dev/null 2>&1; then
    ELEPHANT_VERSION=$(elephant version 2>/dev/null)
    [[ -n "$ELEPHANT_VERSION" ]]
    check "elephant version responds (got: ${ELEPHANT_VERSION:-<empty>})" "$?"

    elephant listproviders >/dev/null 2>&1
    check "elephant listproviders responds" "$?"
else
    echo "  [FAIL] elephant binary not found"
    FAIL=$((FAIL + 1))
    echo "  [FAIL] elephant listproviders responds"
    FAIL=$((FAIL + 1))
fi

if command -v walker >/dev/null 2>&1; then
    WALKER_VERSION=$(walker --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
    [[ -n "$WALKER_VERSION" ]]
    check "walker version responds (got: ${WALKER_VERSION:-<empty>})" "$?"
else
    echo "  [FAIL] walker binary not found"
    FAIL=$((FAIL + 1))
fi

pgrep -x walker >/dev/null 2>&1
check "walker process running" "$?"

pgrep -x elephant >/dev/null 2>&1
check "elephant process running" "$?"

# Provider parity: compare `elephant listproviders` (active) against every
# provider walker/config.toml actually references — the `[providers]
# default` array and every `[[providers.prefixes]]` entry (Pitfall W2).
# A non-empty gap here is expected/known until Phase 3's INST-01 install
# verification loop lands (AUDIT.md findings #7/#19/#20) — this check
# reports the gap, it does not attempt to fix it (no package installs
# happen in this plan).
if command -v elephant >/dev/null 2>&1 && [[ -f "$WALKER_CONFIG" ]]; then
    ACTIVE_PROVIDERS=$(elephant listproviders 2>/dev/null)
    CONFIGURED_PROVIDERS=$(awk '
        /^default[[:space:]]*=[[:space:]]*\[/{inarr=1}
        inarr{print}
        inarr && /\]/{inarr=0}
        /provider[[:space:]]*=[[:space:]]*"/{print}
    ' "$WALKER_CONFIG" | grep -oE '"[a-zA-Z_]+"' | tr -d '"' | sort -u)

    MISSING=""
    for p in $CONFIGURED_PROVIDERS; do
        if ! printf '%s\n' "$ACTIVE_PROVIDERS" | grep -qx "$p"; then
            MISSING="$MISSING $p"
        fi
    done
    MISSING="$(echo "$MISSING" | xargs)"
    [[ -z "$MISSING" ]]
    check "elephant listproviders covers all configured walker providers (missing: ${MISSING:-none})" "$?"
else
    echo "  [SKIP] elephant/walker provider parity ($WALKER_CONFIG or elephant not found)"
fi

echo ""
echo "Summary: ${PASS} passed, ${FAIL} failed"
[[ "$FAIL" -eq 0 ]]
exit $?
